# Manifest of expected secrets. `bash scripts/init.sh` reads this file to
# decide which variables to prompt for; each `KEY=` line becomes a prompt
# and the leading `#` comment becomes the prompt's help text. `.env` itself
# is gitignored.

# Slack incoming-webhook URL the briefing is posted to.
# Create one at https://api.slack.com/messaging/webhooks for the channel
# that should receive the daily brief. Format: https://hooks.slack.com/services/T.../B.../...
SLACK_WEBHOOK_URL=

# YouTube Data API v3 key used to fetch recent uploads from configured channels.
# Create at https://console.cloud.google.com → APIs & Services → Credentials.
# Enable the YouTube Data API v3 on the project before generating the key.
YOUTUBE_API_KEY=
