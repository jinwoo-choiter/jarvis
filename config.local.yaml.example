# Copy to `config.local.yaml` and edit. `config.local.yaml` is gitignored.
# Any key present here overrides the same key in `config.yaml`.

arxiv:
  categories:
    - cs.RO
    # - cs.AI
    # - cs.LG

youtube:
  channels:
    # - "UCxxxxxxxxxxxxxxxxxxxxxx"   # Replace with real channel IDs.
    # - "UCyyyyyyyyyyyyyyyyyyyyyy"

# Optional: free-form keyword themes for the synthesis prompt's web_search step.
# These are read by the prompt, not by the Python fetchers.
search_themes:
  career:
    # - "humanoid robot announcements"
    # - "real-time control framework"
  leisure:
    # - "concert announcements <your city>"
    # - "exhibition opening <your city>"
